#!/usr/bin/env bash
set -euo pipefail

MVN_VERSION="${MVN_VERSION:-3.9.11}"
BASE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CACHE_DIR="${BASE_DIR}/.cache"
MAVEN_DIR="${CACHE_DIR}/apache-maven-${MVN_VERSION}"
ARCHIVE="${CACHE_DIR}/apache-maven-${MVN_VERSION}-bin.tar.gz"
URL="https://archive.apache.org/dist/maven/maven-3/${MVN_VERSION}/binaries/apache-maven-${MVN_VERSION}-bin.tar.gz"

mkdir -p "${CACHE_DIR}"

if [[ ! -x "${MAVEN_DIR}/bin/mvn" ]]; then
  if [[ ! -f "${ARCHIVE}" ]]; then
    curl -fsSL "${URL}" -o "${ARCHIVE}"
  fi
  rm -rf "${MAVEN_DIR}"
  tar -xzf "${ARCHIVE}" -C "${CACHE_DIR}"
fi

exec "${MAVEN_DIR}/bin/mvn" "$@"
